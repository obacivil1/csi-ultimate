{
  "language": "ar",
  "search": {
    "method": "GET",
    "endpoint": "/ar/search",
    "param": "q"
  },
  "extraction": {
    "adIdPattern": "-(\\d+)$",
    "titleCleanup": ["opensooq.com", "السوق المفتوح"],
    "phoneRegion": "SAUDI_ARABIA",
    "countryCodes": [966, 971, 973, 974, 965, 968],
    "currencies": ["SAR", "AED", "KWD", "QAR", "OMR", "BHD", "EGP", "JOD", "USD"],
    "selectors": {
      "title": ["h1", "[class*='title']"],
      "description": ["[class*='description']", "[class*='content']"],
      "phone": ["a[href^='tel:']", "[class*='phone']"],
      "email": ["a[href^='mailto:']"],
      "whatsapp": ["a[href*='wa.me']", "a[href*='whatsapp.com/send']"],
      "location": ["[class*='location']", "[class*='city']"],
      "price": ["[class*='price']"],
      "company": ["[class*='company']", "[class*='seller']"],
      "breadcrumb": [".breadcrumb a", "[class*='breadcrumb']"],
      "date": ["time", "[class*='date']"]
    }
  },
  "pagination": {
    "nextSelector": "a[rel='next'], a.next, [class*='next'] a"
  },
  "categories": {
    "autoDiscover": false
  }
}
