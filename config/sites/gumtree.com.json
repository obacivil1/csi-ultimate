{
  "language": "en",
  "search": {
    "method": "GET",
    "endpoint": "/search",
    "param": "q"
  },
  "extraction": {
    "titleCleanup": ["gumtree.com", "Gumtree"],
    "phoneRegion": "UK",
    "countryCodes": [44],
    "currencies": ["GBP", "EUR", "USD"],
    "selectors": {
      "title": ["[data-q='vip-title']", "h1"],
      "description": ["[data-q='description']", "[class*='description']"],
      "phone": ["a[href^='tel:']", "[class*='phone']"],
      "email": ["a[href^='mailto:']"],
      "location": ["[data-q='ad-location']"],
      "price": ["[data-q='ad-price']", "[class*='price']"],
      "company": ["[data-q='seller-name-large-screen']", "[data-q='seller-name']"],
      "breadcrumb": ["[class*='breadcrumb'] a"],
      "date": ["[class*='date']", "[data-q*='Posted']", "time"]
    }
  },
  "pagination": {
    "nextSelector": "a[rel='next'], a.next, [class*='next'] a, [data-q='next']"
  },
  "categories": {
    "autoDiscover": false
  }
}
